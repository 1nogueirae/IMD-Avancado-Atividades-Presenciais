<%
  let eletronicos = ['telefone', 'nokia', 'televisao', 'apple', 'smartphone']
  let alimentos = ['alimentação', 'tomate']
  let outros = ['home', 'tinta', 'panela']

  function setBadgeClass(tagName) {
    if (eletronicos.includes(tagName)) {
      return 'badge bg-info'
    } else if (alimentos.includes(tagName)) {
      return 'badge bg-danger'
    } else if (outros.includes(tagName)) {
      return 'badge bg-warning'
    } else {
      return 'badge bg-secondary'
    }
  }

  function formatPublishDate(createdAt) {
    if (!createdAt) return 'Sem data de publicacao'

    const date = new Date(createdAt)
    if (Number.isNaN(date.getTime())) return 'Sem data de publicacao'

    return date.toLocaleDateString('pt-BR', {
      day: '2-digit',
      month: '2-digit',
      year: 'numeric'
    })
  }
%>

<% produtos.forEach(function(produto) { %>
  <div class="col">
    <div class="card h-100 shadow-sm">
      <% if (produto.foto) { %>
        <img class="card-img-top" src="<%= produto.foto %>" alt="<%= produto.nome %>">
      <% } else { %>
        <img class="card-img-top" src="http://localhost:8080/static/uploads/placeholder.png" alt="Imagem não disponível">
      <% } %>

      <div class="card-body d-flex flex-column">
        <h5 class="card-title mb-2"><%= produto.nome %></h5>
        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
          <div class="d-flex gap-1 flex-wrap justify-content-end">
            <% if (produto.Tags.length) { %>
              <% produto.Tags.forEach(function(tag) { %>
                <span class="<%= setBadgeClass(tag.nome) %>"><%= tag.nome %></span>
              <% }); %>
            <% } else { %>
              <span class="badge bg-secondary">Sem tags</span>
            <% } %>
          </div>
          <span class="badge bg-success" style="width: fit-content;">R$ <%= Number(produto.preco).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
        </div>
        <p class="card-text text-muted small mb-0" style="text-align: justify;"><%= produto.descricao %></p>
        <small class="text-muted d-block mt-auto pt-2">Publicado em: <%= formatPublishDate(produto.createdAt) %></small>
      </div>
    </div>
  </div>
<% }); %>